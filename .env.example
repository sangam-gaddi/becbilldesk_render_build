# ============================================
# 🔐 DATABASE CONFIGURATION
# ============================================
MONGODB_URI=mongodb+srv://your-user:your-password@cluster.mongodb.net/database?retryWrites=true&w=majority

# ============================================
# 🔑 JWT AUTHENTICATION
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-characters-long
JWT_EXPIRES_IN=7d

# ============================================
# 🌐 APP CONFIGURATION
# ============================================
# Update this to your Render URL after deployment
NEXT_PUBLIC_APP_URL=https://your-app-name.onrender.com

# ============================================
# 💰 CRYPTO PAYMENT - SEPOLIA TESTNET
# ============================================
# WalletConnect Cloud Project ID (get from https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-project-id

# College Treasury Wallet (Sepolia)
NEXT_PUBLIC_COLLEGE_WALLET_ADDRESS=0xYourWalletAddress

# Payment Amount (in ETH)
NEXT_PUBLIC_PAYMENT_AMOUNT_ETH=0.0001

# Network Configuration
NEXT_PUBLIC_NETWORK_NAME=Sepolia Testnet
NEXT_PUBLIC_CHAIN_ID=11155111

# ============================================
# 🎤 AI VOICE AGENT - LIVEKIT (Optional - Run locally)
# ============================================
# Get from: https://cloud.livekit.io
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret
LIVEKIT_URL=wss://your-app.livekit.cloud

# ============================================
# 🎧 SPEECH-TO-TEXT - DEEPGRAM (Optional - Run locally)
# ============================================
# Get from: https://console.deepgram.com
DEEPGRAM_API_KEY=your-deepgram-api-key

# ============================================
# 🧠 LLM - CEREBRAS (Optional - Run locally)
# ============================================
# Get from: https://cloud.cerebras.ai
CEREBRAS_API_KEY=your-cerebras-api-key

# ============================================
# 🔊 TEXT-TO-SPEECH - CARTESIA (Optional - Run locally)
# ============================================
# Get from: https://cartesia.ai
CARTESIA_API_KEY=your-cartesia-api-key
